    "@types/node": "^20",
    "@vitest/coverage-v8": "^4.1.0",
    "eslint": "^9.0.0",
    "tsx": "^4.19.0",
    "typescript": "~5.8.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^4.1.0"
  }
}
