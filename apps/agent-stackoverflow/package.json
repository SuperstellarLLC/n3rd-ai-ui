{
  "name": "@n3rd-ai/agent-stackoverflow",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "Q&A knowledge base MCP server — the 'Stack Overflow for AI agents'",
  "scripts": {
    "start": "tsx src/index.ts",
    "build": "tsc --noEmit",
