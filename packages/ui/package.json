{
  "name": "@n3rd-ai/ui",
  "version": "0.4.3",
  "description": "Terminal-first UI framework for Next.js. ASCII everything. Zero images. Pure text.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./hooks": {
      "types": "./dist/hooks/index.d.ts",
      "import": "./dist/hooks/index.js"
    },
    "./utils": {
      "types": "./dist/utils/index.d.ts",
      "import": "./dist/utils/index.js"
    },
    "./theme/unicorn.css": "./dist/theme/presets/unicorn.css",
    "./theme/classic.css": "./dist/theme/presets/classic.css",
    "./theme/retro.css": "./dist/theme/presets/retro.css",
    "./theme/paper.css": "./dist/theme/presets/paper.css",
    "./styles.css": "./dist/index.css",
    "./theme/fonts.css": "./dist/theme/fonts.css",
    "./theme/tokens.css": "./dist/theme/tokens.css",
    "./theme/reset.css": "./dist/theme/reset.css"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:ci": "vitest run --coverage",
    "test:watch": "vitest",
    "prepublishOnly": "pnpm run build"
  },
  "keywords": [
    "terminal",
    "ascii",
    "ui",
    "nextjs",
    "react",
    "components",
    "monospace",
    "tui",
    "mcp"
  ],
  "author": "Superstellar LLC",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/SuperstellarLLC/n3rd-ai",
    "directory": "packages/ui"
  },
  "bugs": {
    "url": "https://github.com/SuperstellarLLC/n3rd-ai/issues"
  },
  "homepage": "https://n3rd.ai",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "sideEffects": [
    "**/*.css",
    "./dist/index.js",
    "./dist/chunk-*.js",
    "./dist/hooks/index.js"
  ],
  "peerDependencies": {
    "next": ">=14.0.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@testing-library/jest-dom": "^6.4.0",
    "@testing-library/react": "^15.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitest/coverage-v8": "^4.1.0",
    "eslint": "^9.0.0",
    "eslint-plugin-react": "^7.34.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "jsdom": "^29.0.0",
    "next": "^15.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "size-limit": "^12.0.1",
    "@size-limit/preset-small-lib": "^11.0.0",
    "tsup": "^8.0.0",
    "typescript": "~5.8.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^4.1.0"
  }
}
